# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development
# Comma-separated origins allowed to call this API
CORS_ORIGINS=http://localhost:5555,https://flueai.io
# Frontend base URL (Stripe success/cancel redirects)
FRONTEND_URL=http://localhost:5555

# ── Supabase (auth + service role) ───────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Legacy JWT secret (Supabase Dashboard → Settings → API → JWT Secret)
# Required for Bearer token auth — NOT the anon or service_role key
SUPABASE_JWT_SECRET=
# Service role key — server-side table access (bypasses RLS). NEVER expose to clients.
SUPABASE_SERVICE_KEY=

# ── AI providers ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MODEL_HAIKU=claude-3-5-haiku-20241022
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_VOICE_MODEL=gpt-4o-mini
REPLICATE_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=
DEEPGRAM_API_KEY=

# ── Stripe ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
